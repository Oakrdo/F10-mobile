-- Função para obter caminho completo
local function getFullPath(instance)
    local parts = {}
    local current = instance
    
    while current and current ~= game do
        table.insert(parts, 1, current.Name)
        current = current.Parent
    end
    
    return table.concat(parts, ".")
end

-- FUNÇÃO PARA LER SCRIPT
local function readScript(scriptObj)
    local success, content = pcall(function()
        return scriptObj.Source
    end)
    
    if success and content then
        -- Mostra o script no visualizador
        local lines = {}
        for line in string.gmatch(content, "([^\n]*)\n?") do
            table.insert(lines, line)
        end
        
        scriptText.Text = content
        scriptText.Size = UDim2.new(1, -10, 0, math.max(200, #lines * 20))
        scriptScrollFrame.CanvasSize = UDim2.new(0, 0, 0, math.max(200, #lines * 20) + 50)
        
        -- Esconde infoText e mostra o visualizador
        infoText.Visible = false
        scriptScrollFrame.Visible = true
        closeScriptBtn.Visible = true
        
        return true
    else
        infoText.Text = "❌ Não foi possível ler o script!\n\n" .. tostring(content)
        return false
    end
end

-- Função para verificar navegável
local function isNavigable(obj)
    return obj:IsA("Folder") or 
           obj:IsA("Model") or 
           obj:IsA("Tool") or
           obj:IsA("Player") or
           obj:IsA("Backpack") or
           obj:IsA("StarterGui") or
           obj:IsA("StarterPack") or
           obj:IsA("StarterPlayer") or
           (obj:IsA("Instance") and #obj:GetChildren() > 0)
end

-- Função para obter ícone
local function getObjectIcon(obj)
    if obj:IsA("Folder") then
        return "📁"
    elseif obj:IsA("Model") then
        return "🗂️"
    elseif obj:IsA("Part") or obj:IsA("MeshPart") or obj:IsA("BasePart") then
        return "🧱"
    elseif obj:IsA("Script") then
        return "📜⚡"
    elseif obj:IsA("LocalScript") then
        return "📜🖥️"
    elseif obj:IsA("ModuleScript") then
        return "📜📦"
    elseif obj:IsA("Tool") then
        return "🔧"
    elseif obj:IsA("GuiObject") or obj:IsA("ScreenGui") then
        return "🖼️"
    elseif obj:IsA("Camera") then
        return "📷"
    else
        if string.match(obj.Name, "^%{.*%}$") then
            return "📁"
        end
        return "📄"
    end
end

-- Função para selecionar objeto
local function selectObject(obj)
    selectedPart = obj
    lastPath = getFullPath(obj)
    
    -- Fecha visualizador de script se estiver aberto
    scriptScrollFrame.Visible = false
    infoText.Visible = true
    closeScriptBtn.Visible = false
    
    local extraInfo = ""
    
    -- Se for script, oferece botão para ler
    if obj:IsA("Script") or obj:IsA("LocalScript") or obj:IsA("ModuleScript") then
        extraInfo = "\n\n📜 É UM SCRIPT! Clique em 'Ler Script' abaixo para ver o código!"
        
        -- Botão ler script (dinâmico)
        local readBtn = Instance.new("TextButton")
        readBtn.Size = UDim2.new(0.45, 0, 0.3, 0)
        readBtn.Position = UDim2.new(0.01, 0, 0.7, 0)
        readBtn.Text = "📖 LER SCRIPT"
        readBtn.BackgroundColor3 = Color3.fromRGB(50, 100, 50)
        readBtn.TextColor3 = Color3.new(1, 1, 1)
        readBtn.TextScaled = true
        readBtn.Parent = infoFrame
        
        readBtn.MouseButton1Click:Connect(function()
            readScript(obj)
            readBtn:Destroy()
        end)
        
        -- Remove depois de 5 segundos se não clicar
        task.wait(5)
        if readBtn and readBtn.Parent then
            readBtn:Destroy()
        end
    elseif obj:IsA("TextLabel") or obj:IsA("TextButton") then
        extraInfo = "\n\n📝 TEXTO: \"" .. (obj.Text or "") .. "\""
    end
    
    infoText.Text = "✅ SELECIONADO!\n\n📦 Nome: " .. obj.Name .. 
                   "\n🔧 Classe: " .. obj.ClassName .. 
                   extraInfo ..
                   "\n📂 Caminho:\n" .. lastPath
    
    -- Feedback visual
    local highlight = Instance.new("SelectionBox")
    highlight.Adornee = obj
    highlight.Color3 = Color3.fromRGB(0, 200, 255)
    highlight.LineThickness = 0.05
    game:GetService("Debris"):AddItem(highlight, 1)
end

-- Função para listar objetos (GUI da esquerda)
local function listObjects(parent)
    isSearchMode = false
    searchBox.Text = ""
    
    if #navigationHistory == 0 or navigationHistory[#navigationHistory] ~= parent then
        table.insert(navigationHistory, parent)
        historyIndex = #navigationHistory
    end
    
    currentParent = parent
    title.Text = "📱 EXPLORER - " .. parent.Name
    
    for _, child in pairs(scrollFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    local yPosition = 0
    local itemHeight = 38
    local itemsFound = 0
    
    local currentPath = getFullPath(parent)
    
    -- Botão de caminho
    local pathButton = Instance.new("TextButton")
    pathButton.Text = "📍 " .. currentPath
    pathButton.Size = UDim2.new(1, -10, 0, 25)
    pathButton.Position = UDim2.new(0, 5, 0, yPosition)
    pathButton.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    pathButton.TextColor3 = Color3.fromRGB(200, 200, 200)
    pathButton.TextScaled = true
    pathButton.TextXAlignment = Enum.TextXAlignment.Left
    pathButton.Parent = scrollFrame
    
    pathButton.MouseButton1Click:Connect(function()
        if setclipboard then
            setclipboard(currentPath)
            infoText.Text = "✅ Caminho copiado!\n\n" .. currentPath
        end
    end)
    
    yPosition = yPosition + 30
    
    -- Botão voltar
    if parent ~= workspace and parent ~= game then
        local backButton = Instance.new("TextButton")
        backButton.Text = "⬅️ VOLTAR PARA " .. (parent.Parent and parent.Parent.Name or "RAIZ")
        backButton.Size = UDim2.new(1, -10, 0, itemHeight)
        backButton.Position = UDim2.new(0, 5, 0, yPosition)
        backButton.BackgroundColor3 = Color3.fromRGB(100, 70, 70)
        backButton.TextColor3 = Color3.new(1, 1, 1)
        backButton.TextScaled = true
        backButton.Parent = scrollFrame
        
        backButton.MouseButton1Click:Connect(function()
            if parent.Parent then
                listObjects(parent.Parent)
            end
        end)
        
        yPosition = yPosition + itemHeight + 5
        itemsFound = itemsFound + 1
    end
    
    -- Listar filhos
    local children = {}
    for _, child in pairs(parent:GetChildren()) do
        table.insert(children, child)
    end
    
    table.sort(children, function(a, b)
        local aIsNav = isNavigable(a)
        local bIsNav = isNavigable(b)
        if aIsNav ~= bIsNav then
            return aIsNav
        end
        return string.lower(a.Name) < string.lower(b.Name)
    end)
    
    for _, child in pairs(children) do
        local icon = getObjectIcon(child)
        local navigable = isNavigable(child)
        local isScript = child:IsA("Script") or child:IsA("LocalScript") or child:IsA("ModuleScript")
        
        local childCount = #child:GetChildren()
        local countText = ""
        if #child:GetChildren() > 0 then
            countText = " (" .. childCount .. ")"
        end
        
        local button = Instance.new("TextButton")
        button.Text = icon .. " " .. child.Name .. " [" .. child.ClassName .. "]" .. countText
        button.Size = UDim2.new(1, -10, 0, itemHeight)
        button.Position = UDim2.new(0, 5, 0, yPosition)
        
        if isScript then
            button.BackgroundColor3 = Color3.fromRGB(80, 50, 30) -- Cor diferente para scripts
        elseif navigable then
            button.BackgroundColor3 = Color3.fromRGB(50, 70, 90)
        else
            button.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        end
        
        button.TextColor3 = Color3.new(1, 1, 1)
        button.TextScaled = true
        button.TextXAlignment = Enum.TextXAlignment.Left
        button.Parent = scrollFrame
        
        button.MouseButton1Click:Connect(function()
            if navigable then
                listObjects(child)
            elseif isScript then
                selectObject(child)
                readScript(child) -- Abre automaticamente o script!
            else
                selectObject(child)
            end
        end)
        
        yPosition = yPosition + itemHeight + 2
        itemsFound = itemsFound + 1
    end
    
    if itemsFound == 0 then
        local emptyLabel = Instance.new("TextLabel")
        emptyLabel.Text = "📂 Esta pasta está vazia"
        emptyLabel.Size = UDim2.new(1, -10, 0, 40)
        emptyLabel.Position = UDim2.new(0, 5, 0, yPosition + 10)
        emptyLabel.BackgroundTransparency = 1
        emptyLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
        emptyLabel.TextScaled = true
        emptyLabel.Parent = scrollFrame
        yPosition = yPosition + 50
    end
    
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, yPosition + 20)
end

-- Função de pesquisa
local function searchObjects(search)
    if search == "" then
        listObjects(currentParent)
        return
    end
    
    isSearchMode = true
    title.Text = "🔍 PESQUISA: \"" .. search .. "\""
    
    for _, child in pairs(scrollFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    local yPosition = 0
    local itemHeight = 38
    local itemsFound = 0
    
    local backButton = Instance.new("TextButton")
    backButton.Text = "⬅️ VOLTAR PARA " .. currentParent.Name
    backButton.Size = UDim2.new(1, -10, 0, itemHeight)
    backButton.Position = UDim2.new(0, 5, 0, yPosition)
    backButton.BackgroundColor3 = Color3.fromRGB(70, 100, 70)
    backButton.TextColor3 = Color3.new(1, 1, 1)
    backButton.TextScaled = true
    backButton.Parent = scrollFrame
    
    backButton.MouseButton1Click:Connect(function()
        searchBox.Text = ""
        listObjects(currentParent)
    end)
    
    yPosition = yPosition + itemHeight + 5
    
    local searchResults = {}
    local searchLower = string.lower(search)
    
    local function searchRecursive(obj, depth)
        if depth > 5 then return end
        
        local nameLower = string.lower(obj.Name)
        local classLower = string.lower(obj.ClassName)
        
        if string.find(nameLower, searchLower, 1, true) or 
           string.find(classLower, searchLower, 1, true) then
            table.insert(searchResults, obj)
        end
        
        for _, child in pairs(obj:GetChildren()) do
            searchRecursive(child, depth + 1)
        end
    end
    
    searchRecursive(currentParent, 0)
    
    table.sort(searchResults, function(a, b)
        return string.lower(a.Name) < string.lower(b.Name)
    end)
    
    for _, obj in pairs(searchResults) do
        local icon = getObjectIcon(obj)
        local navigable = isNavigable(obj)
        local isScript = obj:IsA("Script") or obj:IsA("LocalScript") or obj:IsA("ModuleScript")
        
        local button = Instance.new("TextButton")
        button.Text = icon .. " " .. obj.Name .. " [" .. obj.ClassName .. "]"
        button.Size = UDim2.new(1, -10, 0, itemHeight)
        button.Position = UDim2.new(0, 5, 0, yPosition)
        
        if isScript then
            button.BackgroundColor3 = Color3.fromRGB(80, 50, 30)
        elseif navigable then
            button.BackgroundColor3 = Color3.fromRGB(50, 70, 90)
        else
            button.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        end
        
        button.TextColor3 = Color3.new(1, 1, 1)
        button.TextScaled = true
        button.TextXAlignment = Enum.TextXAlignment.Left
        button.Parent = scrollFrame
        
        button.MouseButton1Click:Connect(function()
            if navigable then
                listObjects(obj)
                searchBox.Text = ""
            elseif isScript then
                selectObject(obj)
                readScript(obj)
            else
                selectObject(obj)
            end
        end)
        
        yPosition = yPosition + itemHeight + 2
        itemsFound = itemsFound + 1
    end
    
    if itemsFound == 0 then
        local noResults = Instance.new("TextLabel")
        noResults.Text = "🔍 Nenhum resultado encontrado para:\n\"" .. search .. "\""
        noResults.Size = UDim2.new(1, -10, 0, 60)
        noResults.Position = UDim2.new(0, 5, 0, yPosition + 10)
        noResults.BackgroundTransparency = 1
        noResults.TextColor3 = Color3.fromRGB(150, 150, 150)
        noResults.TextScaled = true
        noResults.TextWrapped = true
        noResults.Parent = scrollFrame
        yPosition = yPosition + 70
    end
    
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, yPosition + 20)
end

local function performSearch()
    if searchDebounce then
        searchDebounce:Disconnect()
    end
    
    searchDebounce = game:GetService("RunService").Stepped:Connect(function()
        searchDebounce:Disconnect()
        searchDebounce = nil
        
        if searchTerm == "" then
            listObjects(currentParent)
        else
            searchObjects(searchTerm)
        end
    end)
end

